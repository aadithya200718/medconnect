# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS - set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# TiDB Database Connection
TIDB_HOST=your-tidb-host.clusters.tidb-cloud.com
TIDB_PORT=4000
TIDB_USER=your-username
TIDB_PASSWORD=your-password
TIDB_DATABASE=medconnect

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# Twilio Configuration (for OTP SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Blockchain Configuration (Polygon Amoy Testnet)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
PRIVATE_KEY=your-wallet-private-key
CONTRACT_ADDRESS=0x_your_contract_address_here

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
